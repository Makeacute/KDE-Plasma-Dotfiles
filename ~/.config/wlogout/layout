{
    "label" : "lock",
    "action" : "betterlockscreen --lock",
    "text" : "Lock",
    "keybind" : "l"
}
{
    "label" : "windows",
    "action" : "sudo grub-reboot 'osprober-efi-2A0F-06B2' && systemctl reboot",
    "text" : "Windows",
    "keybind" : "w"
}
{
    "label" : "logout",
    "action" : "loginctl terminate-user $USER",
    "text" : "Logout",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Shutdown",
    "keybind" : "s"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspend",
    "keybind" : "u"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reboot",
    "keybind" : "r"
}
