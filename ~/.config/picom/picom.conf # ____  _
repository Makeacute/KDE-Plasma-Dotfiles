blur: {
    method = "dual_kawase";
    strength = 5;
}

blur-background-exclude = [
    "class_g = 'org.vinegarhq.Sober'",
    "class_g = 'geometrydash.exe'",
    "window_type = 'menu'",
    "window_type = 'dropdown_menu'",
    "window_type = 'tooltip'",
    "window_type = 'desktop'",
    "_GTK_FRAME_EXTENTS@:c"
];

#  ____                           _
# / ___| ___ _ __   ___ _ __ __ _| |
#| |  _ / _ \ '_ \ / _ \ '__/ _ | |
#| |_| |  __/ | | |  __/ | | (_| | |
# \____|\___|_| |_|\___|_|  \__,_|_|

daemon = false;
vsync = true;
dbus = false;
mark-wmwin-focused = true;
mark-ovredir-focused = true;
detect-rounded-corners = true;
corner-radius = 15;

rounded-corners-exclude = [
    "class_g = 'Polybar'",
    "window_type = 'desktop'",
    "fullscreen"
];

detect-client-opacity = true;
detect-transient = true;
detect-client-leader = true;

unredir-if-possible-exclude = [];
invert-color-include = [];

use-damage = true;
transparent-clipping = false;
log-level = "warn";
show-all-xerrors = true;
backend = "glx";

animations = ({
    triggers = ["geometry"];
    preset = "geometry-change";
    duration = 0.1;
}, {
    triggers = ["open"];
    preset = "appear";
    duration = 0.20;
    scale = 0.88;
}, {
    triggers = ["close"];
    preset = "disappear";
    duration = 0.20;
    scale = 0.88;
}, {
    triggers = ["show"];
    preset = "appear";
    scale = 0.90;
    duration = 0.20;
}, {
    triggers = ["hide"];
    preset = "disappear";
    scale = 0.90;
    duration = 0.20;
})
